{
  "compilerOptions": {
    "target": "ES2022",

    "module": "ESNext",
    "moduleResolution": "Bundler",

    "lib": ["ES2023"],

    "types": ["node", "vitest/globals"],

    "paths": {
      "@/*": ["./src/*"]
    },

    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,

    "strict": true,

    "skipLibCheck": true,

    "isolatedModules": true
  },
  "exclude": ["node_modules", "**/*.test.ts", "**/*.spec.ts", "src/tests"]
}
