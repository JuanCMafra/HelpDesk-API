{
  "name": "api-help-desk",
  "version": "1.0.0",
  "description": "An API for a call management system",
  "main": "src/server.ts",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "tsx --watch --env-file .env src/server.ts",
    "test": "vitest run",
    "test:dev": "vitest --watch",
    "build": "tsup src/server.ts --out-dir build",
    "start": "node build/server.js"
  },
  "author": "Juan Mafra",
  "license": "ISC",
  "dependencies": {
    "@prisma/client": "^7.8.0",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.6",
    "dayjs": "^1.11.21",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "pg": "^8.21.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.19",
    "@types/dotenv": "^6.1.1",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.9.1",
    "@types/supertest": "^7.2.0",
    "prisma": "^7.8.0",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "tsup": "^8.5.1",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.7"
  }
}
